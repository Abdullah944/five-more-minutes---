; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Five More Minutes! ⏰💤"
config/description="Protect your sleep at all costs. A cozy-comedy roguelike survivor."
config/tags=PackedStringArray("2d", "mobile", "roguelike")
run/main_scene="res://scenes/main/main_menu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://art/icons/icon_512.png"

[autoload]

SaveManager="*res://scripts/autoload/save_manager.gd"
MetaProgression="*res://scripts/autoload/meta_progression.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
UpgradeManager="*res://scripts/autoload/upgrade_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SleepMeter="*res://scripts/autoload/sleep_meter.gd"
MissionManager="*res://scripts/autoload/mission_manager.gd"
SettingsManager="*res://scripts/autoload/settings_manager.gd"
TelegramBot="*res://scripts/autoload/telegram_bot.gd"
UIPalette="*res://scripts/ui/ui_palette.gd"
SafeAreaUtil="*res://scripts/ui/safe_area_util.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=6

[gui]

theme/custom="res://art/theme/game_theme.tres"

