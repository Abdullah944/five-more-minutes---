

# Optional. Local dev only: SpriteCook batch tool (`tools/spritecook_batch.py`) — never ship in game export.
# SPRITECOOK_API_KEY=

# Optional. If set, must match the key used when the save was created (default ships in code).
SAVE_ENCRYPTION_KEY=

# --- Godot Editor only (game does not read these): Android export / signing ---
# If export fails with "Could not find debug keystore", either set paths in
# Editor Settings → Export → Android → Keystore, OR export after exporting these in your shell:
#   export GODOT_ANDROID_KEYSTORE_DEBUG_PATH="$HOME/.android/debug.keystore"
#   export GODOT_ANDROID_KEYSTORE_DEBUG_USER="androiddebugkey"
#   export GODOT_ANDROID_KEYSTORE_DEBUG_PASSWORD="android"
# Then launch Godot from that same terminal session (so it inherits the vars).
# Docs: https://docs.godotengine.org/en/stable/tutorials/export/exporting_for_android.html#environment-variables
#
# On macOS, exporting from Godot opened via Dock ignores shell env. Either set keystore paths in
# Editor Settings → Export → Android → Keystore, OR launch Godot via:
#   ./scripts/launch_godot_with_android_keystore.sh --path "$(pwd)"
